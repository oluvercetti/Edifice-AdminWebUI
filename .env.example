# Base URL of the Edifice API (shared NestJS backend). The admin console talks
# to the same backend as the investor app, and the URL MUST include the /v1
# prefix — every endpoint is mounted under /v1, so without it requests 404.
#
# Local dev:
NEXT_PUBLIC_API_URL=http://localhost:4000/v1
#
# Production example (note the /v1):
#   NEXT_PUBLIC_API_URL=https://edifice-backend.onrender.com/v1
#
# NEXT_PUBLIC_* values are baked in at build time, so after changing this on the
# host (e.g. Vercel) you must REDEPLOY — a restart won't pick it up.
